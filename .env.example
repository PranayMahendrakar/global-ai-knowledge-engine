# Global AI Knowledge Engine - Configuration
# Copy this file to .env and fill in your values

# ==========================================
# KNOWLEDGE ENGINE SETTINGS
# ==========================================

# Topics to track (comma-separated)
TOPICS=artificial intelligence,machine learning,climate change,technology,science,geopolitics

# Update interval in seconds (default: 3600 = 1 hour)
UPDATE_INTERVAL=3600

# Auto-save interval in seconds (default: 300 = 5 minutes)
SAVE_INTERVAL=300

# Maximum articles per topic per scrape cycle
MAX_ARTICLES_PER_TOPIC=20

# ==========================================
# STORAGE
# ==========================================

# Local file storage
GRAPH_STORAGE_PATH=data/knowledge_graph.json

# Redis cache (optional)
REDIS_URL=redis://localhost:6379/0

# MongoDB (optional, for persistent article storage)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=knowledge_engine

# Neo4j Graph Database (optional, for production)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ==========================================
# NLP / AI MODELS
# ==========================================

# spaCy model to use
SPACY_MODEL=en_core_web_sm

# HuggingFace model for advanced NER (optional)
HF_NER_MODEL=dslim/bert-base-NER
HF_CACHE_DIR=.cache/huggingface

# OpenAI API (optional, for enhanced entity linking)
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# API SERVER
# ==========================================

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret

# ==========================================
# SCRAPING
# ==========================================

# Request timeout in seconds
SCRAPER_TIMEOUT=30

# Max concurrent requests
SCRAPER_MAX_CONCURRENT=10

# Respect robots.txt
RESPECT_ROBOTS_TXT=true

# Request delay (seconds between requests to same domain)
REQUEST_DELAY=1.0

# ==========================================
# LOGGING
# ==========================================

LOG_LEVEL=INFO
LOG_FILE=logs/knowledge_engine.log
LOG_ROTATION=100 MB
